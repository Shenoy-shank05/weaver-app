{
  "name": "weaver",
  "version": "1.0.0",
  "private": true,
  "description": "Web Extraction & AI Verification for Employment Reliability",
  "workspaces": [
    "client",
    "server",
    "ml_service"
  ],
  "scripts": {
    "build": "npm run build --workspace=client && npm run build --workspace=server",
